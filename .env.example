# Copy to .env and fill in from your Supabase project (Settings -> API).
# The anon key is safe to ship in the app: Row-Level Security is the access gate.
# NEVER put the service_role key here or anywhere in this repo.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
